#!/usr/bin/env bash
# SessionStart hook for harness-workflow plugin

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read using-harness-workflow content if it exists
using_content=""
using_skill_path="${PLUGIN_ROOT}/skills/using-harness-workflow/SKILL.md"
if [ -f "$using_skill_path" ]; then
    using_content=$(cat "$using_skill_path" 2>&1 || echo "Error reading using-harness-workflow skill")
fi

# Escape string for JSON embedding using bash parameter substitution.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

if [ -n "$using_content" ]; then
    using_escaped=$(escape_for_json "$using_content")
    session_context="<EXTREMELY_IMPORTANT>\nYou have harness-workflow plugin installed.\n\n**Below is the full content of your 'harness-workflow:using-harness-workflow' skill - your introduction to using harness-workflow skills. For all other skills, use the 'Skill' tool:**\n\n${using_escaped}\n</EXTREMELY_IMPORTANT>"

    # Output context injection as JSON.
    if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
        printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
    elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
        printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
    else
        printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
    fi
fi

exit 0
