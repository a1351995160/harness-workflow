#!/usr/bin/env bash
# Stop hook: quality-gates
# Stage-aware quality enforcement before Claude stops.
# Exit 0 = allow stop, Exit 2 = block stop + inject error feedback.
# Implements the "Ralph Loop" (back-pressure) from the research docs.
# v1.5.0: Enhanced to enforce gates at ALL stages, not just execute.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Find project directory with .harness/
project_dir=""
search_dir="$(pwd)"
while [ -n "$search_dir" ] && [ "$search_dir" != "/" ]; do
    if [ -d "$search_dir/.harness" ]; then
        project_dir="$search_dir"
        break
    fi
    search_dir=$(dirname "$search_dir")
done

# No .harness/ found — skip quality gates (not a harness project)
if [ -z "$project_dir" ]; then
    exit 0
fi

# Check if state.json exists
state_file="$project_dir/.harness/state.json"
if [ ! -f "$state_file" ]; then
    exit 0
fi

# Extract current stage from state.json
stage=""
if grep -q '"current_stage"' "$state_file" 2>/dev/null; then
    stage=$(grep -oP '"current_stage"\s*:\s*"\K[^"]+' "$state_file" 2>/dev/null | head -1 || echo "")
fi
# Fallback: check stages object for active/in_progress status
if [ -z "$stage" ]; then
    for s in intent spec plan harness execute; do
        if grep -A2 "\"$s\"" "$state_file" 2>/dev/null | grep -q '"in_progress\|"active'; then
            stage="$s"
            break
        fi
    done
fi

# No active stage — skip
if [ -z "$stage" ]; then
    exit 0
fi

# ── Stage-aware gate routing ────────────────────────────────────
# Early stages (intent/spec/plan/harness): artifact validation
# Execute stage: full build-verify

case "$stage" in
    intent|spec|plan|harness)
        # Use check_status.py --gate for artifact validation
        python_cmd=""
        if command -v python3 &>/dev/null; then
            python_cmd="python3"
        elif command -v python &>/dev/null; then
            python_cmd="python"
        fi

        if [ -z "$python_cmd" ]; then
            exit 0
        fi

        gate_output=$($python_cmd "$PLUGIN_ROOT/scripts/run.py" check_status.py \
            --gate "$stage" --project-dir "$project_dir" 2>&1) || gate_exit=$? || gate_exit=0

        # Gate passed — allow stop
        if [ "$gate_exit" -eq 0 ]; then
            exit 0
        fi

        # Gate failed — block with blocker info
        truncated=$(echo "$gate_output" | tail -20)
        cat <<MSG >&2
[harness-workflow] BLOCKED: Quality gate failed at '${stage}' stage.
Cannot stop until required artifacts are complete.

Gate check output:
---
$truncated
---

Complete the missing artifacts, then the quality gate will pass on next stop attempt.
MSG
        exit 2
        ;;
esac

# ── Execute stage: full build-verify ────────────────────────────

# ── Run build-verify ────────────────────────────────────────
# Use the plugin's Python scripts for the actual verification
python_cmd=""
if command -v python3 &>/dev/null; then
    python_cmd="python3"
elif command -v python &>/dev/null; then
    python_cmd="python"
fi

if [ -z "$python_cmd" ]; then
    # No Python — can't run build-verify, allow stop
    exit 0
fi

# Run build_verify.py with tight loop, single iteration
result=$($python_cmd "$PLUGIN_ROOT/scripts/run.py" build_verify.py \
    --loop tight --max-iterations 1 --project-dir "$project_dir" 2>&1) || exit_code=$? || exit_code=0

# Exit code 0 = all checks passed → allow stop
if [ "$exit_code" -eq 0 ]; then
    exit 0
fi

# Exit code 2 = doom loop → block with human intervention message
if [ "$exit_code" -eq 2 ]; then
    cat <<MSG >&2
[harness-workflow] BLOCKED: Doom loop detected during quality gate check.
The build-verify loop has detected repeated failures with no progress.
Human intervention is required to break the cycle.

Suggested actions:
1. Review the error logs above
2. Try a different approach to the failing code
3. Run /harness-workflow:status for detailed diagnostics
4. Use /harness-workflow:verify for full spec verification
MSG
    exit 2
fi

# Exit code 1 = build/test failure → block with error feedback (back-pressure)
# Truncate output to prevent context overflow (max 50 lines)
truncated=$(echo "$result" | tail -50)
cat <<MSG >&2
[harness-workflow] BLOCKED: Quality gate failed. Cannot stop until issues are resolved.

Build-verify output (last 50 lines):
---
$truncated
---

Fix the errors above, then the quality gate will pass on next stop attempt.
MSG
exit 2
