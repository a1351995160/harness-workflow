#!/usr/bin/env bash
# PreToolUse hook: sanitize-input
# Uses updatedInput to auto-sanitize content before Claude writes it.
# Scans for hardcoded secrets and redacts them proactively.
# Runs FIRST in the PreToolUse chain (before enforce-boundary).
set -euo pipefail

# Read stdin JSON from Claude Code
input=$(cat || true)

# Use Python for reliable JSON parsing (Python is already a dependency)
# On Windows, python3 may be a Store alias that doesn't actually run — verify with -c
python_cmd=""
if command -v python3 &>/dev/null && python3 -c "pass" 2>/dev/null; then
    python_cmd="python3"
elif command -v python &>/dev/null && python -c "pass" 2>/dev/null; then
    python_cmd="python"
fi

# No Python — can't parse JSON reliably, allow
if [ -z "$python_cmd" ]; then
    exit 0
fi

# Delegate to inline Python for JSON parsing + secret scanning
result=$($python_cmd -c '
import sys, json, re

try:
    data = json.loads(sys.stdin.read())
except:
    sys.exit(0)

tool_input = data.get("tool_input", data)
tool_name = data.get("tool_name", "")
file_path = tool_input.get("file_path", "")

# Only scan source/config files
src_exts = (".ts", ".tsx", ".js", ".jsx", ".py", ".java", ".go", ".rs",
            ".rb", ".yaml", ".yml", ".json", ".toml", ".cfg", ".ini", ".conf")
if not any(file_path.endswith(e) for e in src_exts):
    sys.exit(0)

# Extract content field
content = ""
field_name = ""
if "content" in tool_input:
    content = tool_input["content"]
    field_name = "content"
elif "new_string" in tool_input:
    content = tool_input["new_string"]
    field_name = "new_string"

if not content:
    sys.exit(0)

# Secret patterns
patterns = [
    (r"(?i)(api[_-]?key|apikey)(\s*=\s*[\"'"'"'])[^\"'"'"']{16,}([\"'"'"'])",
     r"\1\2***REDACTED***\3", "API key"),
    (r"(?i)(password|passwd|pwd)(\s*=\s*[\"'"'"'])[^\"'"'"']+([\"'"'"'])",
     r"\1\2***REDACTED***\3", "password"),
    (r"(?i)(secret|token|auth[_-]?token)(\s*=\s*[\"'"'"'])[^\"'"'"']{20,}([\"'"'"'])",
     r"\1\2***REDACTED***\3", "secret/token"),
    (r"AKIA[0-9A-Z]{16}",
     "***REDACTED_AWS_KEY***", "AWS key"),
    (r"-----BEGIN\s+(RSA\s+|EC\s+|OPENSSH\s+)?PRIVATE KEY-----.*?-----END\s+(RSA\s+|EC\s+|OPENSSH\s+)?PRIVATE KEY-----",
     "***REDACTED_PRIVATE_KEY***", "private key"),
]

redaction_count = 0
redaction_summary = []
sanitized = content

for pattern, replacement, label in patterns:
    if re.search(pattern, sanitized, re.DOTALL):
        sanitized = re.sub(pattern, replacement, sanitized, flags=re.IGNORECASE)
        redaction_count += 1
        redaction_summary.append(label)

if redaction_count == 0:
    sys.exit(0)

# Content unchanged despite match (edge case)
if sanitized == content:
    sys.exit(0)

# Build JSON output with updatedInput
summary = ", ".join(redaction_summary)
context_msg = f"[harness-workflow] Sanitized {redaction_count} secret(s) in {file_path}: {summary}. Original values replaced with ***REDACTED***."

output = {
    "hookSpecificOutput": {
        "updatedInput": {
            field_name: sanitized,
            "file_path": file_path
        },
        "additionalContext": context_msg
    }
}

print(json.dumps(output))
' <<< "$input" 2>/dev/null) || exit_code=$? || exit_code=0

# Python exited with 0 but no output = no redactions needed
if [ -z "$result" ]; then
    exit 0
fi

# Output the JSON from Python
printf '%s\n' "$result"
exit 0
