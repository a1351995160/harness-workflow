#!/usr/bin/env bash
# PreToolUse hook: enforce-boundary
# Intercepts Write/Edit tool calls. Blocks writes to protected files and
# warns on writes outside the current design.md scope.
set -euo pipefail

# Read stdin JSON from Claude Code
input=$(cat || true)

# Extract file_path from tool_input using simple grep (no jq dependency)
file_path=""
if echo "$input" | grep -q '"file_path"'; then
    file_path=$(echo "$input" | sed 's/.*"file_path"[[:space:]]*:[[:space:]]*"//' | sed 's/".*//' | head -1 || true)
fi

# No file_path found — allow (not a file write operation we track)
if [ -z "$file_path" ]; then
    exit 0
fi

# ── Layer 1: Hard blacklist — always block ──────────────────
# These files are never safe for AI to modify directly.
basename=$(basename "$file_path")
case "$basename" in
    .env|.env.*|*.secret|*.pem|*.key|id_rsa*|id_ed25519*|credentials*|*.keystore)
        cat <<'MSG' >&2
[harness-workflow] BLOCKED: Protected file detected.
Reason: This file type (.env, secrets, credentials) is on the hard blacklist.
Action: Modify this file manually if needed. AI modification is not allowed.
MSG
        exit 2
        ;;
    package-lock.json|pnpm-lock.yaml|yarn.lock|Gemfile.lock|poetry.lock|uv.lock)
        cat <<'MSG' >&2
[harness-workflow] BLOCKED: Lock file detected.
Reason: Lock files must be regenerated by package managers, not edited directly.
Action: Run the appropriate install command instead.
MSG
        exit 2
        ;;
esac

# Block any path containing secrets/credentials
case "$file_path" in
    */secrets/*|*/credentials/*|*/.ssh/*|*/private/*)
        cat <<'MSG' >&2
[harness-workflow] BLOCKED: Protected directory detected.
Reason: Path contains a protected directory (secrets/, credentials/, .ssh/, private/).
Action: Modify this file manually if needed.
MSG
        exit 2
        ;;
esac

# ── Layer 2: Scope boundary check (soft — warn only) ───────
# If .harness/state.json exists and there's an active design.md,
# warn when writing to files outside the designed scope.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Find project root by walking up from file_path looking for .harness/
project_dir=""
file_dir=$(dirname "$file_path" 2>/dev/null || echo ".")
if [ -d "$file_dir" ]; then
    search_dir=$(cd "$file_dir" 2>/dev/null && pwd || echo "")
else
    search_dir="$(pwd)"
fi
while [ -n "$search_dir" ] && [ "$search_dir" != "/" ]; do
    if [ -d "$search_dir/.harness" ]; then
        project_dir="$search_dir"
        break
    fi
    search_dir=$(dirname "$search_dir")
done

# No .harness/ found — skip scope check
if [ -z "$project_dir" ]; then
    exit 0
fi

# Find active design.md
design_file=""
for f in "$project_dir"/openspec/changes/*/design.md; do
    if [ -f "$f" ]; then
        design_file="$f"
        break
    fi
done

# No design.md — skip scope check
if [ -z "$design_file" ] || [ ! -f "$design_file" ]; then
    exit 0
fi

# Extract file/component references from design.md
# Look for paths in code blocks, inline code, and explicit file references
design_mentions=$(grep -oE '(src|lib|app|components|pages|api|test|tests|spec|scripts|config|hooks|models|views|controllers|services|middleware|utils|types|interfaces)/[a-zA-Z0-9_./-]+\.(py|ts|tsx|js|jsx|go|java|rs|rb|php|cs|sql|yaml|yml|json|md)' "$design_file" 2>/dev/null || true)

if [ -z "$design_mentions" ]; then
    # Could not extract file references — allow with no warning
    exit 0
fi

# Check if file_path matches any mentioned path
matched=false
while IFS= read -r pattern; do
    [ -z "$pattern" ] && continue
    case "$file_path" in
        *"$pattern"*)
            matched=true
            break
            ;;
    esac
done <<< "$design_mentions"

if [ "$matched" = false ]; then
    # File is outside design scope — emit warning via stdout (not block)
    warning=$(cat <<EOF
{"hookSpecificOutput":{"additionalContext":"[harness-workflow] WARNING: $file_path is outside the current design.md scope. If this change is intentional, update design.md to include this file."}}
EOF
)
    echo "$warning"
fi

# Allow the write (warning is informational only)
exit 0
